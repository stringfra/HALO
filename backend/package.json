    "qa:smoke:standard-flows": "node --env-file=.env scripts/qa-smoke-standard-flows.js",
    "dev": "node --watch --env-file=.env src/server.js",
    "start": "node --env-file=.env src/server.js",
    "test": "node --test tests/**/*.test.js"
  },
